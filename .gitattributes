# Normalise line endings to LF in the repo (deploy target is Linux/Docker).
* text=auto eol=lf

# Binary assets — never normalise or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# Lockfiles — keep but don't show in diffs.
pnpm-lock.yaml -diff
uv.lock -diff
