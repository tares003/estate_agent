{
  "name": "@estate/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Estate Platform application — a single Next.js (App Router) app (Payload CMS mounted later at /admin/cms). Serves every user-facing surface.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "payload": "payload",
    "generate:types": "payload generate:types"
  },
  "dependencies": {
    "@estate/db": "workspace:*",
    "@estate/entitlement": "workspace:*",
    "@estate/i18n": "workspace:*",
    "@estate/tokens": "workspace:*",
    "@estate/ui": "workspace:*",
    "@estate/validators": "workspace:*",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "graphql": "^16.14.1",
    "next": "^16.2.6",
    "payload": "3.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@estate/config": "workspace:*",
    "@playwright/test": "^1.48.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "pg": "^8.13.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
