// Estate Platform — Prisma schema.
//
// Shared-DB + Row-Level-Security multi-tenancy (CLAUDE.md §9 / EPIC-S): every
// tenant-owned table carries tenant_id; RLS policies enforce isolation at the
// data layer (see migrations/raw/0002_rls_policies.sql). The per-request tenant
// GUC (`app.current_tenant_id`) is set by the client extension in src/.
//
// This wave lands the multi-tenancy spine + the cross-cutting tables
// (audit_logs, consent_logs, notification_logs). The full §J per-entity catalogue
// (properties, enquiries, viewings, …) lands in a dedicated follow-on migration
// set. PostGIS + RLS + custom indexes live in raw SQL under migrations/raw/.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The platform operator's customer — an estate agency. NOT itself tenant-scoped
/// (it is the tenant registry); operator-only access. `enabled_packs` holds the
/// optional pack slugs the tenant has switched on (core is implicit). EPIC-AD.
model PlatformTenant {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique
  name         String
  customDomain String?      @unique @map("custom_domain")
  status       TenantStatus @default(active)
  enabledPacks Json         @default("[]") @map("enabled_packs")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  users                User[]
  branches             Branch[]
  agents               Agent[]
  properties           Property[]
  enquiries            Enquiry[]
  assignmentRules      AssignmentRule[]
  viewings             Viewing[]
  valuations           Valuation[]
  repairRequests       RepairRequest[]
  contacts             Contact[]
  propertyImages       PropertyImage[]
  propertyDocuments    PropertyDocument[]
  notes                Note[]
  propertyStatusEvents PropertyStatusEvent[]
  enquiryStatusEvents  EnquiryStatusEvent[]
  repairStatusEvents   RepairStatusEvent[]
  repairFiles          RepairFile[]
  repairCategories     RepairCategory[]
  contractors          Contractor[]
  feedback             Feedback[]
  sdltConfig           SdltConfig?
  savedProperties      SavedProperty[]
  mortgageRateConfig   MortgageRateConfig?
  mortgageRatePresets  MortgageRatePreset[]
  blogAuthors          BlogAuthor[]
  blogCategories       BlogCategory[]
  blogPostTags         BlogPostTag[]
  blogPosts            BlogPost[]
  areaGuides           AreaGuide[]
  areaGuideSections    AreaGuideSection[]
  sessions             Session[]
  accounts             Account[]
  verifications        Verification[]
  twoFactors           TwoFactor[]

  @@map("platform_tenants")
}

enum TenantStatus {
  active
  suspended
  deprovisioned

  @@map("tenant_status")
}

/// A staff user belonging to a tenant agency. Tenant-scoped (RLS). This is also
/// better-auth's `user` (EPIC-N, CLAUDE.md §9): the existing table is EXTENDED with
/// the adapter's columns (emailVerified/image) and the twoFactor plugin's
/// twoFactorEnabled flag, rather than introducing a second identity table.
/// Identity is PER-TENANT — the @@unique([tenantId, email]) is retained, so the
/// same email may exist once per tenant.
model User {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  email            String
  name             String
  role             String
  /// Discriminates a staff member (back-office RBAC role applies) from a
  /// registered customer account holder (EPIC-T; PRODUCT.md §3 — "Customer" is
  /// reserved for account holders). Defaults to `staff` so existing rows + the
  /// staff-session seam are unchanged; the customer-session seam admits only
  /// `customer`.
  type             String   @default("staff")
  emailVerified    Boolean  @default(false) @map("email_verified")
  /// EPIC-T FR-T-1 — a customer's optional marketing opt-in, captured at
  /// registration and editable later (FR-T-11). A SEPARATE decision from the
  /// mandatory GDPR consent (which is logged in consent_logs, not here).
  /// Defaults to false so existing staff rows + an opt-out registration are
  /// unchanged; only an explicit opt-in flips it.
  marketingOptIn   Boolean  @default(false) @map("marketing_opt_in")
  image            String?
  twoFactorEnabled Boolean? @map("two_factor_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant          PlatformTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions        Session[]
  accounts        Account[]
  twoFactors      TwoFactor[]
  savedProperties SavedProperty[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// EPIC-T FR-T-5/6 — a property a registered customer has saved to favourites.
/// Tenant-scoped (RLS), keyed to the customer (user) and the catalogue property.
/// The @@unique([tenantId, userId, propertyId]) makes a save idempotent: the
/// toggle upserts/deletes against it rather than creating duplicate rows. Both
/// FKs cascade — deleting the tenant, the customer, or the property erases the
/// save. The persisted row is what makes the heart's state survive navigation +
/// sign-out/sign-in (FR-T-6).
model SavedProperty {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, propertyId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("saved_properties")
}

/// Append-only audit trail. Every state-changing action writes one row via the
/// audit() helper (CI guard G4). Tenant-scoped (nullable for operator actions).
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  actor     String
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  diff      Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

/// GDPR consent record captured on personal-data form submission via
/// recordConsent() (CI guard G5). Tenant-scoped.
model ConsentLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  scope       String
  subject     String
  consentText String   @map("consent_text")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("consent_logs")
}

/// Outbound notification record written by notify() (master spec §H.13).
/// Tenant-scoped.
model NotificationLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  event     String
  channel   String
  recipient String
  status    String   @default("queued")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("notification_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// EPIC-N — Better Auth adapter tables (CLAUDE.md §9; better-auth@1.6.15).
//
// These four models ARE the better-auth Prisma-adapter contract: the camelCase
// FIELD names are the exact identifiers better-auth reads/writes; the @map column
// names are ours (better-auth never sees a column name). The field set is
// generated from the installed package's own getAuthTables — not guessed.
//
// RLS exception (migrations/raw/0012_better_auth_tables.sql): unlike every other
// tenant table, these are NOT under the per-request tenant_isolation FORCE-RLS
// policy. The adapter reads/writes them BEFORE a session exists — it is resolving
// the very session that would set app.current_tenant_id — so the standard policy
// would admit zero rows and break sign-in. Isolation is instead enforced at the
// APP layer: the Better Auth adapter (B78) connects through a privileged
// BYPASSRLS role and a Prisma $extends hook injects `tenant_id = <current tenant>`
// into every read/write/where for these models (failing closed when no tenant
// context is set). Every model below therefore carries `tenantId` AND a real
// `tenant PlatformTenant` FK (onDelete: Cascade — deleting a tenant erases its auth
// rows, incl. verifications that have no user chain; defence in depth at the DB
// layer behind the app-layer injection), backstopped by the structural user_id →
// user chain. These columns/FKs/indexes are created by `prisma db push` from this
// schema — there is deliberately NO raw ADD COLUMN migration (a plain uuid column
// is Prisma-expressible, unlike the PostGIS column added in 0004). The tables are
// DORMANT until the route mount (B78) constructs the Better Auth instance.
// ─────────────────────────────────────────────────────────────────────────────

/// A signed-in session (prisma.session). `token` is the session secret; `tenantId`
/// is the additionalField the session cookie carries (CLAUDE.md §9), denormalised
/// here so a resolved session names its tenant without a second read. Cascades
/// with its user.
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("sessions")
}

/// A provider/credential link for a user (prisma.account) — one row per OAuth
/// provider connection (microsoft/google/apple) or the email+password credential.
/// `password` is null for OAuth accounts; the token columns hold the provider's
/// access/refresh/id tokens. Cascades with its user. `tenantId` is NOT a
/// better-auth field — it is denormalised here so the auth adapter (B78) can scope
/// the OAuth-account lookup (by accountId+providerId) to the current tenant; under
/// per-tenant identity the same provider account may exist once per tenant.
model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id") @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("accounts")
}

/// A short-lived verification value (prisma.verification) — backs the magic-link
/// (vendor/landlord/tenant portals) and email-verification flows. `identifier` is
/// the email/key, `value` the token, `expiresAt` its bound. It precedes the user
/// being resolved, but it IS issued on a tenant subdomain, so `tenantId` (not a
/// better-auth field) is stamped by the auth adapter (B78) and scopes consumption:
/// two tenants can issue a link to the same email, so the lookup-by-identifier
/// must be tenant-scoped to prevent cross-tenant token consumption.
model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  tenantId   String   @map("tenant_id") @db.Uuid
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([identifier])
  @@index([tenantId])
  @@map("verifications")
}

/// A user's TOTP enrolment (prisma.twoFactor) — the twoFactor plugin's store for
/// staff 2FA (FR-N-2). `secret` is the TOTP seed; `backupCodes` the recovery set.
/// Cascades with its user. No timestamps — matches better-auth's model. `tenantId`
/// (not a better-auth field) is stamped by the auth adapter (B78) for uniform
/// per-tenant scoping alongside the structural user_id → user chain.
model TwoFactor {
  id          String @id @default(uuid()) @db.Uuid
  secret      String
  backupCodes String @map("backup_codes")
  userId      String @map("user_id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("two_factors")
}

// ─────────────────────────────────────────────────────────────────────────────
// §J core (always-on / core-pack) catalogue + CRM entities.
//
// Every model below is TENANT-SCOPED: it carries tenant_id (uuid), relates back
// to the PlatformTenant registry, and is isolated by the tenant_isolation RLS
// policy in migrations/raw/0003_core_entities_rls.sql. Table + column + enum
// names map to snake_case (@@map / @map) to satisfy the canonical-naming guards
// (PRODUCT.md §2/§3). The catalogue entity is Property (never Listing/House);
// the inbound-lead entity is Enquiry (never Lead/Inquiry).
//
// Attribute coverage here is the core spine of master spec §F/§J; vertical-pack
// attributes (commercial / new-homes / business-transfer) and the satellite
// entities (images, documents, notes, history) land in their owning epics.
// ─────────────────────────────────────────────────────────────────────────────

/// An agency office (master spec §J.2). Public-facing branch directory + the
/// owning branch of every property and agent.
model Branch {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  slug         String
  name         String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  town         String
  county       String?
  postcode     String
  country      String   @default("United Kingdom")
  phone        String?
  email        String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agents     Agent[]
  properties Property[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("branches")
}

/// A staff member shown on the public Team page (master spec §J.2). This is the
/// public-facing profile and is distinct from the auth User; an Agent may carry
/// an optional link to a User when the same person also signs in.
model Agent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  slug       String
  name       String
  roleTitle  String?  @map("role_title")
  department String?
  bio        String?
  email      String?
  phone      String?
  whatsapp   String?
  photoUrl   String?  @map("photo_url")
  isActive   Boolean  @default(true) @map("is_active")
  showOnTeam Boolean  @default(true) @map("show_on_team")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("agents")
}

/// The catalogue entity (master spec §F/§J.3). NEVER named Listing/House. One
/// row per property, discriminated by listingType (FR-F-2 — there is NEVER a
/// table per vertical); the per-vertical F.1–F.6 extensions hang on this same
/// entity, validated conditionally on listingType (FR-F-3). FR-F-1: this entity
/// captures EVERY master-spec Section F attribute. Money fields (price, deposits,
/// ground rent, service charge) are stored in pence. The optional foreign-key
/// columns (primaryAgentId / secondaryAgentId / created/updated user) are SOFT
/// references (no hard FK) so the property survives an agent or staff member
/// leaving — the relational @relation only binds branch.
model Property {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  branchId String? @map("branch_id") @db.Uuid

  // ── §F identification + lifecycle ──────────────────────────────────────────
  reference         String
  externalId        String?           @map("external_id")
  slug              String
  title             String?
  listingType       ListingType       @default(residential) @map("listing_type")
  saleType          SaleType          @map("sale_type")
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  marketStatus      MarketStatus      @default(for_sale) @map("market_status")
  isNewHome         Boolean           @default(false) @map("is_new_home")
  isFeatured        Boolean           @default(false) @map("is_featured")
  showOnHomepage    Boolean           @default(false) @map("show_on_homepage")
  showPrice         Boolean           @default(true) @map("show_price")
  displayOrder      Int               @default(0) @map("display_order")

  // ── §F pricing ─────────────────────────────────────────────────────────────
  price            Int?
  priceQualifier   PriceQualifier @default(none) @map("price_qualifier")
  rentFrequency    RentFrequency? @map("rent_frequency")
  depositAmount    Int?           @map("deposit_amount")
  holdingDeposit   Int?           @map("holding_deposit")
  minTenancyMonths Int?           @map("min_tenancy_months")
  letType          LetType?       @map("let_type")
  availableFrom    DateTime?      @map("available_from")

  // ── §F specification ─────────────────────────────────────────────────────────
  category            PropertyCategory?
  subCategory         String?           @map("sub_category")
  bedrooms            Int?
  bathrooms           Int?
  receptions          Int?
  internalSqft        Int?              @map("internal_sqft")
  internalSqm         Int?              @map("internal_sqm")
  plotSqft            Int?              @map("plot_sqft")
  plotSqm             Int?              @map("plot_sqm")
  tenure              Tenure?
  leaseYearsRemaining Int?              @map("lease_years_remaining")
  groundRent          Int?              @map("ground_rent")
  serviceCharge       Int?              @map("service_charge")
  councilTaxBand      CouncilTaxBand?   @map("council_tax_band")
  epcRating           EpcRating?        @map("epc_rating")
  epcScore            Int?              @map("epc_score")
  furnishedStatus     FurnishedStatus?  @map("furnished_status")
  parking             String?
  outdoorSpace        String?           @map("outdoor_space")
  chainStatus         String?           @map("chain_status")
  heating             String?
  constructionYear    Int?              @map("construction_year")
  listedStatus        String?           @map("listed_status")

  // ── §F location ──────────────────────────────────────────────────────────────
  internalAddressLine1 String? @map("internal_address_line1")
  internalAddressLine2 String? @map("internal_address_line2")
  displayAddress       String  @map("display_address")
  postcode             String
  postcodePrefix       String? @map("postcode_prefix")
  town                 String?
  city                 String?
  county               String?
  country              String  @default("United Kingdom")
  latitude             Float?
  longitude            Float?
  hideExactAddress     Boolean @default(false) @map("hide_exact_address")

  // ── §F descriptions ──────────────────────────────────────────────────────────
  shortDescription String? @map("short_description")
  description      String?
  keyFeatures      Json    @default("[]") @map("key_features")
  areaDescription  String? @map("area_description")
  additionalNotes  String? @map("additional_notes")

  // ── §F media (headline URLs; the gallery + paperwork rows are satellites) ────
  mainImageUrl    String? @map("main_image_url")
  videoTourUrl    String? @map("video_tour_url")
  virtualTourUrl  String? @map("virtual_tour_url")
  brochureUrl     String? @map("brochure_url")
  materialInfoUrl String? @map("material_info_url")

  // ── §F agent + branch assignment (soft refs; branch binds via @relation) ─────
  primaryAgentId   String? @map("primary_agent_id") @db.Uuid
  secondaryAgentId String? @map("secondary_agent_id") @db.Uuid
  contactPhone     String? @map("contact_phone")
  contactEmail     String? @map("contact_email")

  // ── §F SEO ───────────────────────────────────────────────────────────────────
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")
  ogImageUrl      String? @map("og_image_url")
  canonicalUrl    String? @map("canonical_url")
  noIndex         Boolean @default(false) @map("no_index")

  // ── §F audit metadata + soft delete (FR-F-10) ────────────────────────────────
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  publishedAt     DateTime? @map("published_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       PlatformTenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  enquiries    Enquiry[]
  viewings     Viewing[]
  repairs      RepairRequest[]
  images       PropertyImage[]
  documents    PropertyDocument[]
  statusEvents PropertyStatusEvent[]
  savedBy      SavedProperty[]

  @@unique([tenantId, reference])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, marketStatus])
  @@index([tenantId, saleType, listingType])
  @@map("properties")
}

/// The unifying inbound-lead record (master spec §J.4). NEVER named Lead/Inquiry.
model Enquiry {
  id         String        @id @default(uuid()) @db.Uuid
  tenantId   String        @map("tenant_id") @db.Uuid
  propertyId String?       @map("property_id") @db.Uuid
  reference  String?
  leadType   LeadType      @default(buyer_enquiry) @map("lead_type")
  name       String
  email      String
  phone      String?
  message    String
  status     EnquiryStatus @default(new)
  sourceUrl  String?       @map("source_url")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@map("enquiries")
}

/// Append-only audit of an enquiry's status transitions (master spec §I.3) —
/// the CRM activity timeline + the basis for SLA / time-to-first-contact metrics.
/// `fromStatus` is null for the first event. The acting agent is optional
/// (system/import changes carry none). A soft `enquiryId` reference (like
/// Note.entityId) — RLS keeps both rows tenant-isolated.
model EnquiryStatusEvent {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  enquiryId        String         @map("enquiry_id") @db.Uuid
  fromStatus       EnquiryStatus? @map("from_status")
  toStatus         EnquiryStatus  @map("to_status")
  changedByAgentId String?        @map("changed_by_agent_id") @db.Uuid
  changedAt        DateTime       @default(now()) @map("changed_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, enquiryId])
  @@map("enquiry_status_events")
}

/// EPIC-H FR-H-4 (master spec §H.6) — a no-code enquiry-assignment rule. Each row
/// is one `IF <conditions> THEN <assignment>` rule composed in the admin editor.
/// `conditions` (the IF — AND-ed comparisons against an enquiry's lead_type /
/// status / source_url / message / property) and `assignment` (the THEN — an
/// agent or branch target) are JSONB, validated by @estate/validators'
/// assignmentRuleSchema on write. Rules are ordered by `position` per tenant so
/// the runtime router evaluates them top-down, first-match-wins. Tenant-scoped
/// (RLS, migration 0018). "Lead" is a UI label only — the entity is the canonical
/// Enquiry (PRODUCT.md §2/§3).
model AssignmentRule {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String
  conditions Json
  assignment Json
  position   Int      @default(0)
  isEnabled  Boolean  @default(true) @map("is_enabled")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, position])
  @@map("assignment_rules")
}

/// A request to view a property (viewing_request — master spec §J.4).
model Viewing {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  propertyId  String        @map("property_id") @db.Uuid
  name        String
  email       String
  phone       String
  preferredAt DateTime      @map("preferred_at")
  status      ViewingStatus @default(pending)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("viewings")
}

/// A request for a property appraisal (valuation_request — master spec §J.4).
model Valuation {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  name         String
  email        String
  phone        String
  addressLine1 String          @map("address_line1")
  addressLine2 String?         @map("address_line2")
  town         String?
  postcode     String
  propertyType String          @map("property_type")
  bedrooms     Int?
  status       ValuationStatus @default(new)
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("valuations")
}

/// A maintenance ticket raised by a tenant (repair_request — master spec §J.6/§G).
/// propertyId is optional for the property-not-yet-known case (master spec §J.9).
model RepairRequest {
  id                   String        @id @default(uuid()) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  propertyId           String?       @map("property_id") @db.Uuid
  assignedContractorId String?       @map("assigned_contractor_id") @db.Uuid
  // §G.6: the human-readable ticket number (e.g. "RPR-2026-04321"), assigned at
  // submission; per-tenant unique (the spec's UNIQUE, mapped multi-tenant).
  reference            String?
  // The tenant's free-text pointer to their property at intake (§G.6's property
  // address block, collapsed to the committed single-field shape); staff resolve
  // it to `propertyId` in the admin.
  propertyReference    String?       @map("property_reference")
  name                 String
  email                String
  phone                String?
  category             String
  description          String
  urgency              RepairUrgency @default(standard)
  status               RepairStatus  @default(new)
  // §G.6: required commentary when a ticket is rejected ("not our responsibility").
  rejectedReason       String?       @map("rejected_reason")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant             PlatformTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property           Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignedContractor Contractor?         @relation(fields: [assignedContractorId], references: [id], onDelete: SetNull)
  statusEvents       RepairStatusEvent[]
  files              RepairFile[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, urgency])
  @@map("repair_requests")
}

/// The append-only audit of a repair ticket's status transitions — the
/// `repair_status_history` table §G.6 specifies (FR-G-7: every transition records
/// from/to, actor, notes, timestamp). The actor is a soft user reference (like
/// Note.authorAgentId — history survives a staff member leaving; null for
/// system-generated transitions). Tenant-scoped, isolated by the tenant_isolation
/// RLS policy in migrations/raw/0008_repair_status_history_rls.sql.
model RepairStatusEvent {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  repairRequestId String        @map("repair_request_id") @db.Uuid
  fromStatus      RepairStatus? @map("from_status")
  toStatus        RepairStatus  @map("to_status")
  actorUserId     String?       @map("actor_user_id") @db.Uuid
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")

  tenant        PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repairRequest RepairRequest  @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, repairRequestId])
  @@map("repair_status_history")
}

/// A photo / video attached to a repair ticket (master spec §G.6, FR-G-2). The
/// tenant attaches media at intake; staff and contractors add more later
/// (completion photos — FR-G-8). `url` holds the StorageBackend KEY (the spec's
/// file_url column; serving mints signed URLs at render time, CLAUDE.md §9).
/// `fileSizeBytes` is Int (the spec says bigint; 4-byte suffices under the 25MB
/// upload cap and avoids BigInt serialization in the app layer).
model RepairFile {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  repairRequestId String               @map("repair_request_id") @db.Uuid
  url             String               @map("file_url")
  fileName        String               @map("file_name")
  mimeType        String               @map("mime_type")
  fileSizeBytes   Int                  @map("file_size_bytes")
  uploadedBy      RepairFileUploadedBy @default(tenant) @map("uploaded_by")
  createdAt       DateTime             @default(now()) @map("created_at")

  tenant        PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repairRequest RepairRequest  @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, repairRequestId])
  @@map("repair_files")
}

/// Who attached a repair file (master spec §G.6 uploaded_by).
enum RepairFileUploadedBy {
  tenant
  staff
  contractor

  @@map("repair_file_uploaded_by")
}

/// An admin-editable repair category (master spec §G.3, FR-G-4). §G.3 stores the
/// catalogue here so admins can edit labels, icons, default urgency, the
/// auto-assign role, ordering and visibility. The §G.3 default seed lives in
/// @estate/validators (DEFAULT_REPAIR_CATEGORIES) — the source for provisioning a
/// new tenant and the fallback the public form uses before any customisation.
model RepairCategory {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  slug           String
  label          String
  icon           String?
  defaultUrgency RepairUrgency @default(standard) @map("default_urgency")
  autoAssignRole String?       @map("auto_assign_role")
  sortOrder      Int           @default(0) @map("sort_order")
  visible        Boolean       @default(true)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("repair_categories")
}

/// A repair contractor a staff member assigns tickets to (master spec §G.6,
/// FR-G-8). A staff-entered B2B directory record (legitimate-interest basis — not
/// a consenting data subject filling a form). The magic-link the contractor uses
/// to access an assigned ticket is a signed token (no account), so there is no
/// auth row here.
model Contractor {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  email     String
  phone     String?
  trade     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant          PlatformTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedRepairs RepairRequest[]

  @@index([tenantId])
  @@map("contractors")
}

/// EPIC-AC (§B.36 / §J, FR-AC-4): structured feedback captured at a journey moment
/// (after a viewing / sale / tenancy / repair). Holds the rating + optional comment,
/// the publish-as-testimonial consent, the moderation lifecycle (FR-AC-5) and the
/// "needs response" flag for negative sentiment (FR-AC-10). The respondent is
/// anonymous (FR-AC-4); `triggerEntity`/`triggerEntityId` is a SOFT reference to the
/// originating record (viewing/sale/tenancy/repair), so no hard FK. `agentActor`
/// tags the agent for the league-table rollup (FR-AC-7). Tenant-scoped (RLS, 0013).
model Feedback {
  id                   String          @id @default(uuid()) @db.Uuid
  tenantId             String          @map("tenant_id") @db.Uuid
  triggerType          FeedbackTrigger
  triggerEntity        String?         @map("trigger_entity")
  triggerEntityId      String?         @map("trigger_entity_id") @db.Uuid
  respondentRef        String?         @map("respondent_ref")
  agentActor           String?         @map("agent_actor")
  rating               Int
  comment              String?
  publishAsTestimonial Boolean         @default(false) @map("publish_as_testimonial")
  status               FeedbackStatus  @default(pending)
  rejectedReason       String?         @map("rejected_reason")
  needsResponse        Boolean         @default(false) @map("needs_response")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("feedback")
}

/// EPIC-W FR-W-3 — the per-tenant SDLT band configuration backing the indicative
/// stamp-duty calculator. One row per tenant (the @unique on tenant_id) holds the
/// admin-edited band set as JSON in the engine's SdltConfig shape; the public
/// calculator falls back to the engine default when no row exists. Tenant-scoped,
/// isolated by the tenant_isolation RLS policy in migrations/raw/0014_sdlt_config_rls.sql.
model SdltConfig {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @unique @map("tenant_id") @db.Uuid
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sdlt_config")
}

/// EPIC-W FR-W-7 — the per-tenant mortgage-default configuration backing the
/// indicative mortgage calculator. One row per tenant (the @unique on tenant_id)
/// holds the admin-edited defaults as JSON in the engine's MortgageRateConfig shape
/// (illustrative rate / term / deposit % + the last-reviewed date); the public
/// calculator falls back to the engine default when no row exists. Tenant-scoped,
/// isolated by the tenant_isolation RLS policy in migrations/raw/0015_mortgage_rate_config_rls.sql.
model MortgageRateConfig {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @unique @map("tenant_id") @db.Uuid
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("mortgage_rate_config")
}

/// EPIC-W FR-W-8 — an admin-managed mortgage rate preset (a named rate snapshot,
/// e.g. "2-year fixed" / "5-year fixed") backing the public mortgage calculator's
/// preset dropdown. Many per tenant (the @relation back to PlatformTenant); each
/// carries a display label, an illustrative annual rate and a term, plus a
/// sort_order for the dropdown. Tenant-scoped, isolated by the tenant_isolation RLS
/// policy in migrations/raw/0017_mortgage_rate_presets_rls.sql. INDICATIVE ONLY
/// (PRODUCT.md §9 — not financial advice).
model MortgageRatePreset {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  /// Display label shown in the dropdown (e.g. "2-year fixed").
  label             String
  /// Illustrative annual interest rate as a percentage (e.g. 4.79 for 4.79%).
  annualRatePercent Float    @map("annual_rate_percent")
  /// The preset's mortgage term in whole years.
  termYears         Int      @map("term_years")
  /// Ordering position in the dropdown (ascending).
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sortOrder])
  @@map("mortgage_rate_presets")
}

/// EPIC-J knowledge-hub author (master spec §J "Blog author"; §H Blog tab).
/// A by-line for blog posts. Tenant-scoped; the slug is unique per tenant.
/// Isolated by the tenant_isolation RLS policy in migrations/raw/0019_blog_rls.sql.
model BlogAuthor {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  slug      String
  bio       String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts  BlogPost[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_authors")
}

/// EPIC-J knowledge-hub category (master spec §J "Blog category" — slug, label,
/// description, sort order). Tenant-scoped; the slug is unique per tenant.
/// Isolated by the tenant_isolation RLS policy in migrations/raw/0019_blog_rls.sql.
model BlogCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts  BlogPost[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_categories")
}

/// EPIC-J knowledge-hub tag (master spec §J "Blog post tag" — the tag entity in a
/// many-to-many tag-to-post relationship). Tenant-scoped; slug unique per tenant.
/// The posts <-> tags m-n uses Prisma's idiomatic implicit join table.
/// Isolated by the tenant_isolation RLS policy in migrations/raw/0019_blog_rls.sql.
model BlogPostTag {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts  BlogPost[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_post_tags")
}

/// EPIC-J knowledge-hub article (master spec §J "Blog post"; §H Blog tab —
/// title, body, category, tags, author, schedule). The `body` is the block-based
/// source payload (Json, mirroring how the page-builder stores typed sections);
/// `excerpt`, `heroImageUrl` and the `metaTitle`/`metaDescription` SEO fields are
/// nullable. The lifecycle is draft -> scheduled -> published (BlogPostStatus);
/// `scheduledFor` carries the scheduled publication time and `publishedAt` the
/// actual one. Category (m-1) and author (m-1) are nullable and SetNull on delete;
/// tags are a m-n via the implicit join. Tenant-scoped; slug unique per tenant.
/// Isolated by the tenant_isolation RLS policy in migrations/raw/0019_blog_rls.sql.
model BlogPost {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  title             String
  slug              String
  body              Json
  // §J — the pre-rendered HTML cache of `body`, populated on publish (nullable
  // until first render). The source body above is the rich-text/Markdown master.
  renderedHtmlCache String?        @map("rendered_html_cache")
  excerpt           String?
  heroImageUrl      String?        @map("hero_image_url")
  status            BlogPostStatus @default(draft)
  publishedAt       DateTime?      @map("published_at")
  scheduledFor      DateTime?      @map("scheduled_for")
  metaTitle         String?        @map("meta_title")
  metaDescription   String?        @map("meta_description")
  categoryId        String?        @map("category_id") @db.Uuid
  authorId          String?        @map("author_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category BlogCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author   BlogAuthor?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  tags     BlogPostTag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("blog_posts")
}

/// A CRM contact record (master spec §J.5). One unified entity with a role
/// discriminator (landlord / tenant / vendor / buyer) per the brief's open
/// question 1 default-to-separate note; the role is captured on `type`.
model Contact {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  email           String?
  phone           String?
  type            String
  notes           String?
  // FR-I-6: a converted enquiry stamps its id here (soft reference, like
  // Note.authorAgentId — RLS keeps both rows tenant-isolated). Null for contacts
  // created by other means.
  sourceEnquiryId String?   @map("source_enquiry_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type])
  @@map("contacts")
}

/// EPIC-J (master spec §J "Area guide", FR-J-1) — a managed area-guide page. §J
/// specifies it captures: slug, name, introduction, hero image, the postcode
/// prefixes the area covers (used to filter properties), geographic coordinates,
/// meta title, meta description, status and standard timestamps. `slug` is unique
/// per tenant (the public URL key); `postcodePrefixes` is the String[] of covered
/// prefixes that drives the "properties in this area" filter. The page-builder
/// `sections` use the same structure as page sections (§J "Page section"). Tenant-
/// scoped, isolated by the tenant_isolation RLS policy in migrations/raw/0020_area_guides_rls.sql.
model AreaGuide {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  slug             String
  name             String
  introduction     String
  heroImage        String?         @map("hero_image")
  postcodePrefixes String[]        @map("postcode_prefixes")
  latitude         Float?
  longitude        Float?
  metaTitle        String?         @map("meta_title")
  metaDescription  String?         @map("meta_description")
  status           AreaGuideStatus @default(draft)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  tenant   PlatformTenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections AreaGuideSection[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("area_guides")
}

/// EPIC-J (master spec §J — "Page-builder sections for the area guide use the same
/// structure as page sections", §J "Page section"). A typed block within an area
/// guide: a reference to its parent guide, the section `type` (hero, rich text,
/// property carousel and so on — the §D catalogue), the section's typed `data`
/// payload (a structured JSON whose shape matches the section type), the `sortOrder`
/// and a `isVisible` visibility flag. Tenant-scoped, isolated by the tenant_isolation
/// RLS policy in migrations/raw/0020_area_guides_rls.sql. Cascades with both its
/// tenant and its parent guide.
model AreaGuideSection {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  areaGuideId String   @map("area_guide_id") @db.Uuid
  type        String
  data        Json     @default("{}")
  sortOrder   Int      @default(0) @map("sort_order")
  isVisible   Boolean  @default(true) @map("is_visible")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  areaGuide AreaGuide      @relation(fields: [areaGuideId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, areaGuideId])
  @@map("area_guide_sections")
}

/// The publication lifecycle of an area guide (master spec §J "Area guide" status).
/// `draft` while being authored; `published` once live. Public surfaces show only
/// `published` rows.
enum AreaGuideStatus {
  draft
  published

  @@map("area_guide_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// §J satellite entities — the records that hang off the core catalogue.
//
// PropertyImage / PropertyDocument carry a property's media + paperwork
// (EPIC-F §F.1); Note is the polymorphic CRM/internal annotation (master spec
// §J.5); PropertyStatusEvent is the append-only audit of market_status changes
// (master spec §J.3 lifecycle). Every model is TENANT-SCOPED: it carries
// tenant_id (uuid), relates back to the PlatformTenant registry, indexes
// tenant_id, and is isolated by the tenant_isolation RLS policy in
// migrations/raw/0005_satellite_rls.sql.
// ─────────────────────────────────────────────────────────────────────────────

/// A gallery image for a property (EPIC-F §F.1). Uploaded via pre-signed direct
/// upload (FR-F-6); the thumbnail/large variants, `width`/`height` and
/// `fileSizeBytes` are populated by the post-process job (FR-F-7) so are optional.
/// `sortOrder` preserves gallery order across re-uploads; exactly one row per
/// property is the `isPrimary` hero, and `isFloorplan` flags a plan rendered in
/// the floorplan tile rather than the photo gallery.
model PropertyImage {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  propertyId    String   @map("property_id") @db.Uuid
  url           String
  thumbnailUrl  String?  @map("thumbnail_url")
  largeUrl      String?  @map("large_url")
  alt           String
  caption       String?
  sortOrder     Int      @default(0) @map("sort_order")
  isPrimary     Boolean  @default(false) @map("is_primary")
  isFloorplan   Boolean  @default(false) @map("is_floorplan")
  width         Int?
  height        Int?
  fileSizeBytes Int?     @map("file_size_bytes")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("property_images")
}

/// A document attached to a property — EPC, floorplan, brochure, material
/// information, lease, planning, survey or other paperwork (EPIC-F §F.1).
/// Discriminated by DocumentType. `isPublic` controls whether the document is
/// downloadable from the public site; `fileName` / `fileSizeBytes` / `mimeType`
/// are the §F.1 file metadata, optional until the upload post-process records them.
model PropertyDocument {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  propertyId    String       @map("property_id") @db.Uuid
  type          DocumentType
  title         String
  url           String
  fileName      String?      @map("file_name")
  fileSizeBytes Int?         @map("file_size_bytes")
  mimeType      String?      @map("mime_type")
  isPublic      Boolean      @default(true) @map("is_public")
  createdAt     DateTime     @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("property_documents")
}

/// A free-text internal/CRM annotation against any entity (master spec §J.5).
/// Polymorphic by (entityType, entityId) — the simplest defensible shape, so a
/// single table backs notes on properties, enquiries, contacts, etc. The
/// authoring agent is optional (system-generated notes carry none). NOT a hard
/// FK to Agent: notes survive an agent leaving.
model Note {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id") @db.Uuid
  body          String
  isInternal    Boolean  @default(true) @map("is_internal")
  authorAgentId String?  @map("author_agent_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("notes")
}

/// Append-only audit of a property's market_status transitions (master spec
/// §J.3 lifecycle). `fromStatus` is null for the first transition. Reuses the
/// MarketStatus enum. The acting agent is optional (system/import changes carry
/// none).
model PropertyStatusEvent {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  propertyId       String        @map("property_id") @db.Uuid
  fromStatus       MarketStatus? @map("from_status")
  toStatus         MarketStatus  @map("to_status")
  changedByAgentId String?       @map("changed_by_agent_id") @db.Uuid
  changedAt        DateTime      @default(now()) @map("changed_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("property_status_events")
}

/// The vertical discriminator for a property (master spec §F; PRODUCT.md §2).
/// Core ships the always-on verticals; vertical packs (new_homes, commercial,
/// business_transfer, care_homes) extend behaviour, not this enum's core values.
enum ListingType {
  residential
  new_home
  commercial
  business_transfer
  care_home
  land

  @@map("listing_type")
}

/// For sale, or to rent (PRODUCT.md §4: sale_type=sale / sale_type=rent).
enum SaleType {
  sale
  rent

  @@map("sale_type")
}

/// Current sale/let state. Values map 1:1 to the --colour-status-* token set
/// (DESIGN.md): for_sale/to_let are the available states, sold_stc + let_agreed
/// are the dashed-token names in snake_case (PRODUCT.md §4).
enum MarketStatus {
  for_sale
  under_offer
  sold_stc
  sold
  to_let
  let_agreed
  let
  withdrawn

  @@map("market_status")
}

/// The kind of inbound lead (master spec §J.4; PRODUCT.md §4 lead_type).
enum LeadType {
  buyer_enquiry
  viewing_request
  valuation_request
  landlord_enquiry
  tenant_enquiry
  repair_request
  general_contact
  newsletter_signup

  @@map("lead_type")
}

/// Enquiry lifecycle (master spec §J.4).
enum EnquiryStatus {
  new
  contacted
  viewing_booked
  valuation_booked
  waiting
  converted
  lost
  archived

  @@map("enquiry_status")
}

/// Viewing-request lifecycle (master spec §J.4).
enum ViewingStatus {
  pending
  confirmed
  rescheduled
  cancelled
  attended
  no_show

  @@map("viewing_status")
}

/// Valuation-request lifecycle (master spec §J.4).
enum ValuationStatus {
  new
  booked
  completed
  declined
  instructed

  @@map("valuation_status")
}

/// Repair triage urgency (master spec §G). emergency carries the tightest SLA.
enum RepairUrgency {
  emergency
  urgent
  standard
  low

  @@map("repair_urgency")
}

/// Repair-ticket lifecycle — the §G.6-specified enum verbatim. The happy path is
/// new → triaged → contractor_assigned → work_in_progress → awaiting_review →
/// completed (§G.5); awaiting_tenant / on_hold / rejected are the off-path states.
/// The transition allow-list lives in @estate/validators (repair-status.ts).
enum RepairStatus {
  new
  triaged
  contractor_assigned
  work_in_progress
  awaiting_review
  completed
  awaiting_tenant
  on_hold
  rejected

  @@map("repair_status")
}

/// EPIC-AC moderation lifecycle for publish-as-testimonial feedback (FR-AC-5):
/// pending in the queue → published (flows to testimonials) or rejected (with a
/// captured reason). Non-publishable feedback still counts toward the aggregate
/// score (FR-AC-6) but never leaves `pending`.
enum FeedbackStatus {
  pending
  published
  rejected

  @@map("feedback_status")
}

/// EPIC-AC feedback trigger points (FR-AC-1) — the journey moments that prompt a
/// feedback request.
enum FeedbackTrigger {
  viewing_attended
  sale_completed
  tenancy_started
  tenancy_ended
  repair_completed
  mid_year_review

  @@map("feedback_trigger")
}

/// The kind of document attached to a property (EPIC-F §F.1). `epc` is the
/// Energy Performance Certificate; `floorplan` and `brochure` are the common
/// marketing attachments; `material_information` is the Trading Standards /
/// Property Ombudsman Material Information document (PRODUCT.md §6); `lease`,
/// `planning` and `survey` are the conveyancing paperwork; `other` is the
/// catch-all for anything else.
enum DocumentType {
  epc
  floorplan
  brochure
  material_information
  lease
  planning
  survey
  other

  @@map("document_type")
}

/// The publication lifecycle of a property (master spec §F identification +
/// lifecycle). Distinct from MarketStatus (the sale/let state): a property is
/// `draft` while being authored, `in_review` awaiting sign-off, `published` once
/// live, `archived` when retired. Public surfaces show only `published` rows
/// (FR-F-10 additionally hides soft-deleted rows).
enum PublicationStatus {
  draft
  in_review
  published
  archived

  @@map("publication_status")
}

/// The qualifier rendered adjacent to a property's price on every public surface
/// (master spec §F pricing; PRODUCT.md §8 trust marker). `none` means a plain
/// price; `poa` hides the figure ("Price on application"); `from` is the
/// new-homes "from price" qualifier (new_homes pack).
enum PriceQualifier {
  none
  offers_in_excess_of
  offers_over
  offers_in_region_of
  guide_price
  fixed_price
  oiro
  poa
  from

  @@map("price_qualifier")
}

/// Rent frequency for a lettings property (master spec §F.2; PRODUCT.md §8 — a
/// rent figure must always show its frequency). `per_annum` also covers
/// commercial rents (§F.4).
enum RentFrequency {
  per_calendar_month
  per_week
  per_annum

  @@map("rent_frequency")
}

/// The let type for a lettings property (master spec §F.2 / §F lettings pricing).
enum LetType {
  long_let
  short_let
  student
  room
  hmo

  @@map("let_type")
}

/// The property category (master spec §F specification). The vertical category
