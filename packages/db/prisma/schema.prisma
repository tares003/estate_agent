// Estate Platform — Prisma schema.
//
// Shared-DB + Row-Level-Security multi-tenancy (CLAUDE.md §9 / EPIC-S): every
// tenant-owned table carries tenant_id; RLS policies enforce isolation at the
// data layer (see migrations/raw/0002_rls_policies.sql). The per-request tenant
// GUC (`app.current_tenant_id`) is set by the client extension in src/.
//
// This wave lands the multi-tenancy spine + the cross-cutting tables
// (audit_logs, consent_logs, notification_logs). The full §J per-entity catalogue
// (properties, enquiries, viewings, …) lands in a dedicated follow-on migration
// set. PostGIS + RLS + custom indexes live in raw SQL under migrations/raw/.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The platform operator's customer — an estate agency. NOT itself tenant-scoped
/// (it is the tenant registry); operator-only access. `enabled_packs` holds the
/// optional pack slugs the tenant has switched on (core is implicit). EPIC-AD.
model PlatformTenant {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique
  name         String
  customDomain String?      @unique @map("custom_domain")
  status       TenantStatus @default(active)
  enabledPacks Json         @default("[]") @map("enabled_packs")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  users                User[]
  branches             Branch[]
  agents               Agent[]
  properties           Property[]
  enquiries            Enquiry[]
  viewings             Viewing[]
  valuations           Valuation[]
  repairRequests       RepairRequest[]
  contacts             Contact[]
  propertyImages       PropertyImage[]
  propertyDocuments    PropertyDocument[]
  notes                Note[]
  propertyStatusEvents PropertyStatusEvent[]
  enquiryStatusEvents  EnquiryStatusEvent[]
  repairStatusEvents   RepairStatusEvent[]
  repairFiles          RepairFile[]
  repairCategories     RepairCategory[]
  contractors          Contractor[]

  @@map("platform_tenants")
}

enum TenantStatus {
  active
  suspended
  deprovisioned

  @@map("tenant_status")
}

/// A staff user belonging to a tenant agency. Tenant-scoped (RLS).
model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String
  name      String
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Append-only audit trail. Every state-changing action writes one row via the
/// audit() helper (CI guard G4). Tenant-scoped (nullable for operator actions).
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  actor     String
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  diff      Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

/// GDPR consent record captured on personal-data form submission via
/// recordConsent() (CI guard G5). Tenant-scoped.
model ConsentLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  scope       String
  subject     String
  consentText String   @map("consent_text")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("consent_logs")
}

/// Outbound notification record written by notify() (master spec §H.13).
/// Tenant-scoped.
model NotificationLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  event     String
  channel   String
  recipient String
  status    String   @default("queued")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("notification_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// §J core (always-on / core-pack) catalogue + CRM entities.
//
// Every model below is TENANT-SCOPED: it carries tenant_id (uuid), relates back
// to the PlatformTenant registry, and is isolated by the tenant_isolation RLS
// policy in migrations/raw/0003_core_entities_rls.sql. Table + column + enum
// names map to snake_case (@@map / @map) to satisfy the canonical-naming guards
// (PRODUCT.md §2/§3). The catalogue entity is Property (never Listing/House);
// the inbound-lead entity is Enquiry (never Lead/Inquiry).
//
// Attribute coverage here is the core spine of master spec §F/§J; vertical-pack
// attributes (commercial / new-homes / business-transfer) and the satellite
// entities (images, documents, notes, history) land in their owning epics.
// ─────────────────────────────────────────────────────────────────────────────

/// An agency office (master spec §J.2). Public-facing branch directory + the
/// owning branch of every property and agent.
model Branch {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  slug         String
  name         String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  town         String
  county       String?
  postcode     String
  country      String   @default("United Kingdom")
  phone        String?
  email        String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agents     Agent[]
  properties Property[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("branches")
}

/// A staff member shown on the public Team page (master spec §J.2). This is the
/// public-facing profile and is distinct from the auth User; an Agent may carry
/// an optional link to a User when the same person also signs in.
model Agent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  slug       String
  name       String
  roleTitle  String?  @map("role_title")
  department String?
  bio        String?
  email      String?
  phone      String?
  whatsapp   String?
  photoUrl   String?  @map("photo_url")
  isActive   Boolean  @default(true) @map("is_active")
  showOnTeam Boolean  @default(true) @map("show_on_team")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("agents")
}

/// The catalogue entity (master spec §F/§J.3). NEVER named Listing/House. One
/// row per property, discriminated by listingType; price is stored in pence.
model Property {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  branchId       String?      @map("branch_id") @db.Uuid
  reference      String
  slug           String
  title          String?
  displayAddress String       @map("display_address")
  postcode       String
  postcodePrefix String?      @map("postcode_prefix")
  town           String?
  county         String?
  latitude       Float?
  longitude      Float?
  listingType    ListingType  @default(residential) @map("listing_type")
  saleType       SaleType     @map("sale_type")
  marketStatus   MarketStatus @default(for_sale) @map("market_status")
  price          Int?
  bedrooms       Int?
  bathrooms      Int?
  receptions     Int?
  description    String?
  publishedAt    DateTime?    @map("published_at")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant       PlatformTenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  enquiries    Enquiry[]
  viewings     Viewing[]
  repairs      RepairRequest[]
  images       PropertyImage[]
  documents    PropertyDocument[]
  statusEvents PropertyStatusEvent[]

  @@unique([tenantId, reference])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, marketStatus])
  @@index([tenantId, saleType, listingType])
  @@map("properties")
}

/// The unifying inbound-lead record (master spec §J.4). NEVER named Lead/Inquiry.
model Enquiry {
  id         String        @id @default(uuid()) @db.Uuid
  tenantId   String        @map("tenant_id") @db.Uuid
  propertyId String?       @map("property_id") @db.Uuid
  reference  String?
  leadType   LeadType      @default(buyer_enquiry) @map("lead_type")
  name       String
  email      String
  phone      String?
  message    String
  status     EnquiryStatus @default(new)
  sourceUrl  String?       @map("source_url")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@map("enquiries")
}

/// Append-only audit of an enquiry's status transitions (master spec §I.3) —
/// the CRM activity timeline + the basis for SLA / time-to-first-contact metrics.
/// `fromStatus` is null for the first event. The acting agent is optional
/// (system/import changes carry none). A soft `enquiryId` reference (like
/// Note.entityId) — RLS keeps both rows tenant-isolated.
model EnquiryStatusEvent {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  enquiryId        String         @map("enquiry_id") @db.Uuid
  fromStatus       EnquiryStatus? @map("from_status")
  toStatus         EnquiryStatus  @map("to_status")
  changedByAgentId String?        @map("changed_by_agent_id") @db.Uuid
  changedAt        DateTime       @default(now()) @map("changed_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, enquiryId])
  @@map("enquiry_status_events")
}

/// A request to view a property (viewing_request — master spec §J.4).
model Viewing {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  propertyId  String        @map("property_id") @db.Uuid
  name        String
  email       String
  phone       String
  preferredAt DateTime      @map("preferred_at")
  status      ViewingStatus @default(pending)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("viewings")
}

/// A request for a property appraisal (valuation_request — master spec §J.4).
model Valuation {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  name         String
  email        String
  phone        String
  addressLine1 String          @map("address_line1")
  addressLine2 String?         @map("address_line2")
  town         String?
  postcode     String
  propertyType String          @map("property_type")
  bedrooms     Int?
  status       ValuationStatus @default(new)
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("valuations")
}

/// A maintenance ticket raised by a tenant (repair_request — master spec §J.6/§G).
/// propertyId is optional for the property-not-yet-known case (master spec §J.9).
model RepairRequest {
  id                   String        @id @default(uuid()) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  propertyId           String?       @map("property_id") @db.Uuid
  assignedContractorId String?       @map("assigned_contractor_id") @db.Uuid
  // §G.6: the human-readable ticket number (e.g. "RPR-2026-04321"), assigned at
  // submission; per-tenant unique (the spec's UNIQUE, mapped multi-tenant).
  reference            String?
  // The tenant's free-text pointer to their property at intake (§G.6's property
  // address block, collapsed to the committed single-field shape); staff resolve
  // it to `propertyId` in the admin.
  propertyReference    String?       @map("property_reference")
  name                 String
  email                String
  phone                String?
  category             String
  description          String
  urgency              RepairUrgency @default(standard)
  status               RepairStatus  @default(new)
  // §G.6: required commentary when a ticket is rejected ("not our responsibility").
  rejectedReason       String?       @map("rejected_reason")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant             PlatformTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property           Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignedContractor Contractor?         @relation(fields: [assignedContractorId], references: [id], onDelete: SetNull)
  statusEvents       RepairStatusEvent[]
  files              RepairFile[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, urgency])
  @@map("repair_requests")
}

/// The append-only audit of a repair ticket's status transitions — the
/// `repair_status_history` table §G.6 specifies (FR-G-7: every transition records
/// from/to, actor, notes, timestamp). The actor is a soft user reference (like
/// Note.authorAgentId — history survives a staff member leaving; null for
/// system-generated transitions). Tenant-scoped, isolated by the tenant_isolation
/// RLS policy in migrations/raw/0008_repair_status_history_rls.sql.
model RepairStatusEvent {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  repairRequestId String        @map("repair_request_id") @db.Uuid
  fromStatus      RepairStatus? @map("from_status")
  toStatus        RepairStatus  @map("to_status")
  actorUserId     String?       @map("actor_user_id") @db.Uuid
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")

  tenant        PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repairRequest RepairRequest  @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, repairRequestId])
  @@map("repair_status_history")
}

/// A photo / video attached to a repair ticket (master spec §G.6, FR-G-2). The
/// tenant attaches media at intake; staff and contractors add more later
/// (completion photos — FR-G-8). `url` holds the StorageBackend KEY (the spec's
/// file_url column; serving mints signed URLs at render time, CLAUDE.md §9).
/// `fileSizeBytes` is Int (the spec says bigint; 4-byte suffices under the 25MB
/// upload cap and avoids BigInt serialization in the app layer).
model RepairFile {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  repairRequestId String               @map("repair_request_id") @db.Uuid
  url             String               @map("file_url")
  fileName        String               @map("file_name")
  mimeType        String               @map("mime_type")
  fileSizeBytes   Int                  @map("file_size_bytes")
  uploadedBy      RepairFileUploadedBy @default(tenant) @map("uploaded_by")
  createdAt       DateTime             @default(now()) @map("created_at")

  tenant        PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repairRequest RepairRequest  @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, repairRequestId])
  @@map("repair_files")
}

/// Who attached a repair file (master spec §G.6 uploaded_by).
enum RepairFileUploadedBy {
  tenant
  staff
  contractor

  @@map("repair_file_uploaded_by")
}

/// An admin-editable repair category (master spec §G.3, FR-G-4). §G.3 stores the
/// catalogue here so admins can edit labels, icons, default urgency, the
/// auto-assign role, ordering and visibility. The §G.3 default seed lives in
/// @estate/validators (DEFAULT_REPAIR_CATEGORIES) — the source for provisioning a
/// new tenant and the fallback the public form uses before any customisation.
model RepairCategory {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  slug           String
  label          String
  icon           String?
  defaultUrgency RepairUrgency @default(standard) @map("default_urgency")
  autoAssignRole String?       @map("auto_assign_role")
  sortOrder      Int           @default(0) @map("sort_order")
  visible        Boolean       @default(true)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("repair_categories")
}

/// A repair contractor a staff member assigns tickets to (master spec §G.6,
/// FR-G-8). A staff-entered B2B directory record (legitimate-interest basis — not
/// a consenting data subject filling a form). The magic-link the contractor uses
/// to access an assigned ticket is a signed token (no account), so there is no
/// auth row here.
model Contractor {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  email     String
  phone     String?
  trade     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant          PlatformTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedRepairs RepairRequest[]

  @@index([tenantId])
  @@map("contractors")
}

/// A CRM contact record (master spec §J.5). One unified entity with a role
/// discriminator (landlord / tenant / vendor / buyer) per the brief's open
/// question 1 default-to-separate note; the role is captured on `type`.
model Contact {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  email           String?
  phone           String?
  type            String
  notes           String?
  // FR-I-6: a converted enquiry stamps its id here (soft reference, like
  // Note.authorAgentId — RLS keeps both rows tenant-isolated). Null for contacts
  // created by other means.
  sourceEnquiryId String?   @map("source_enquiry_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────────────────────
// §J satellite entities — the records that hang off the core catalogue.
//
// PropertyImage / PropertyDocument carry a property's media + paperwork
// (EPIC-F §F.1); Note is the polymorphic CRM/internal annotation (master spec
// §J.5); PropertyStatusEvent is the append-only audit of market_status changes
// (master spec §J.3 lifecycle). Every model is TENANT-SCOPED: it carries
// tenant_id (uuid), relates back to the PlatformTenant registry, indexes
// tenant_id, and is isolated by the tenant_isolation RLS policy in
// migrations/raw/0005_satellite_rls.sql.
// ─────────────────────────────────────────────────────────────────────────────

/// A gallery image for a property (EPIC-F §F.1). Uploaded via pre-signed direct
/// upload (FR-F-6); `width`/`height` are populated by the post-process job
/// (FR-F-7) so are optional. `sortOrder` preserves gallery order across
/// re-uploads; exactly one row per property is the `isPrimary` hero.
model PropertyImage {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  url        String
  alt        String
  sortOrder  Int      @default(0) @map("sort_order")
  isPrimary  Boolean  @default(false) @map("is_primary")
  width      Int?
  height     Int?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("property_images")
}

/// A document attached to a property — EPC, floorplan, brochure or other
/// paperwork (EPIC-F §F.1). Discriminated by DocumentType.
model PropertyDocument {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  propertyId String       @map("property_id") @db.Uuid
  type       DocumentType
  title      String
  url        String
  createdAt  DateTime     @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("property_documents")
}

/// A free-text internal/CRM annotation against any entity (master spec §J.5).
/// Polymorphic by (entityType, entityId) — the simplest defensible shape, so a
/// single table backs notes on properties, enquiries, contacts, etc. The
/// authoring agent is optional (system-generated notes carry none). NOT a hard
/// FK to Agent: notes survive an agent leaving.
model Note {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id") @db.Uuid
  body          String
  isInternal    Boolean  @default(true) @map("is_internal")
  authorAgentId String?  @map("author_agent_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("notes")
}

/// Append-only audit of a property's market_status transitions (master spec
/// §J.3 lifecycle). `fromStatus` is null for the first transition. Reuses the
/// MarketStatus enum. The acting agent is optional (system/import changes carry
/// none).
model PropertyStatusEvent {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  propertyId       String        @map("property_id") @db.Uuid
  fromStatus       MarketStatus? @map("from_status")
  toStatus         MarketStatus  @map("to_status")
  changedByAgentId String?       @map("changed_by_agent_id") @db.Uuid
  changedAt        DateTime      @default(now()) @map("changed_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  tenant   PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("property_status_events")
}

/// The vertical discriminator for a property (master spec §F; PRODUCT.md §2).
/// Core ships the always-on verticals; vertical packs (new_homes, commercial,
/// business_transfer, care_homes) extend behaviour, not this enum's core values.
enum ListingType {
  residential
  new_home
  commercial
  business_transfer
  care_home
  land

  @@map("listing_type")
}

/// For sale, or to rent (PRODUCT.md §4: sale_type=sale / sale_type=rent).
enum SaleType {
  sale
  rent

  @@map("sale_type")
}

/// Current sale/let state. Values map 1:1 to the --colour-status-* token set
/// (DESIGN.md): for_sale/to_let are the available states, sold_stc + let_agreed
/// are the dashed-token names in snake_case (PRODUCT.md §4).
enum MarketStatus {
  for_sale
  under_offer
  sold_stc
  sold
  to_let
  let_agreed
  let
  withdrawn

  @@map("market_status")
}

/// The kind of inbound lead (master spec §J.4; PRODUCT.md §4 lead_type).
enum LeadType {
  buyer_enquiry
  viewing_request
  valuation_request
  landlord_enquiry
  tenant_enquiry
  repair_request
  general_contact
  newsletter_signup

  @@map("lead_type")
}

/// Enquiry lifecycle (master spec §J.4).
enum EnquiryStatus {
  new
  contacted
  viewing_booked
  valuation_booked
  waiting
  converted
  lost
  archived

  @@map("enquiry_status")
}

/// Viewing-request lifecycle (master spec §J.4).
enum ViewingStatus {
  pending
  confirmed
  rescheduled
  cancelled
  attended
  no_show

  @@map("viewing_status")
}

/// Valuation-request lifecycle (master spec §J.4).
enum ValuationStatus {
  new
  booked
  completed
  declined
  instructed

  @@map("valuation_status")
}

/// Repair triage urgency (master spec §G). emergency carries the tightest SLA.
enum RepairUrgency {
  emergency
  urgent
  standard
  low

  @@map("repair_urgency")
}

/// Repair-ticket lifecycle — the §G.6-specified enum verbatim. The happy path is
/// new → triaged → contractor_assigned → work_in_progress → awaiting_review →
/// completed (§G.5); awaiting_tenant / on_hold / rejected are the off-path states.
/// The transition allow-list lives in @estate/validators (repair-status.ts).
enum RepairStatus {
  new
  triaged
  contractor_assigned
  work_in_progress
  awaiting_review
  completed
  awaiting_tenant
  on_hold
  rejected

  @@map("repair_status")
}

/// The kind of document attached to a property (EPIC-F §F.1). `epc` is the
/// Energy Performance Certificate; `floorplan` and `brochure` are the common
/// marketing attachments; `other` is the catch-all for anything else.
enum DocumentType {
  epc
  floorplan
  brochure
  other

  @@map("document_type")
}
