  a
  b
  c
  d
  e
  f
  g
  pending

  @@map("epc_rating")
}

/// Furnished status of a lettings property (master spec §F.2 / §F specification).
enum FurnishedStatus {
  furnished
  part_furnished
  unfurnished
  optional

  @@map("furnished_status")
}

/// EPIC-J blog-post publication lifecycle (master spec §J "Blog post" status —
