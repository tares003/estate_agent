enum PropertyCategory {
  house
  flat
  bungalow
  studio
  maisonette
  commercial
  land
  room
  retail
  office
  industrial
  leisure
  business
  care_home
  hmo
  mixed_use

  @@map("property_category")
}

/// Tenure of a property (master spec §F specification; surfaced as Material
