enum Tenure {
  freehold
  leasehold
  share_of_freehold
  commonhold
  long_leasehold
  virtual_freehold
  unknown

  @@map("tenure")
}

/// Council tax band (master spec §F specification; Material Information field
/// per PRODUCT.md §6). Bands A–H plus exempt / unknown.
enum CouncilTaxBand {
  a
  b
  c
  d
  e
  f
  g
  h
  exempt
  unknown

